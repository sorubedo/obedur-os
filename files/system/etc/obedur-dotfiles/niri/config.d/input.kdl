input {
    keyboard {
        numlock
    }

    touchpad {
        tap
        dwt
        natural-scroll
        scroll-method "two-finger"
    }

    mouse {
    }

    trackpoint {
        off
    }

    trackball {
        off
    }

    tablet {
        off
    }

    touch {
        off
    }

    warp-mouse-to-focus
    focus-follows-mouse max-scroll-amount="0%"
}
