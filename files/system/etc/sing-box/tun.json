              ".market.xiaomi.com",
              ".wotgame.cn",
              ".wggames.cn",
              ".wowsgame.cn",
              ".wargaming.net",
              ".steamcontent.com"
            ],
            "invert": true
          },
          {
            "query_type": [
              "A",
              "AAAA"
            ]
          }
        ],
        "server": "FakeDns"
      },
      {
        "rule_set": "GeoSite-CN",
        "server": "Local-DNS"
      }
    ],
    "final": "Remote-DNS",
    "strategy": "prefer_ipv4",
    "independent_cache": true
